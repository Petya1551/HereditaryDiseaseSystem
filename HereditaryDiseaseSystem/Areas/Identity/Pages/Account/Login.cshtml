@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
    Layout = null; // We don't want the sidebar on the login screen
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body {
            background-color: #1a333d;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }

        .login-box {
            width: 400px;
        }
    </style>
</head>
<body>
    <div class="login-box">
        <div class="card-master p-4 shadow-lg">
            <div class="text-center mb-4">
                <h4 class="fw-bold text-dark">HDS Portal</h4>
                <p class="text-muted small">Please enter your credentials</p>
            </div>
            <form id="account" method="post">
                <div class="mb-3">
                    <label class="form-label small fw-bold">Email Address</label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" />
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold">Password</label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" />
                </div>
                <button id="login-submit" type="submit" class="btn btn-primary-custom w-100 py-2 mt-2">Sign In</button>
            </form>
            <div class="mt-4 text-center">
                <p class="small text-muted">New user? <a asp-page="./Register" class="text-primary text-decoration-none fw-bold">Create account</a></p>
            </div>
        </div>
    </div>
</body>
</html>