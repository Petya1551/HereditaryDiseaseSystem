@model HereditaryDiseaseSystem.Models.Gene
@{
    ViewData["Title"] = "Gene Specification";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card-master">
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                <h5 class="mb-0">Mapping Details</h5>
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-sm btn-outline-primary">Edit Record</a>
            </div>

            <div class="row mb-3">
                <div class="col-sm-4 text-muted fw-medium">Symbol</div>
                <div class="col-sm-8"><span class="badge bg-primary-subtle text-primary fs-6">@Html.DisplayFor(model => model.Symbol)</span></div>
            </div>

            <div class="row mb-3">
                <div class="col-sm-4 text-muted fw-medium">Chromosome Location</div>
                <div class="col-sm-8 text-dark fw-bold">@Html.DisplayFor(model => model.ChromosomeLocation)</div>
            </div>

            <div class="mt-4 pt-3 border-top">
                <a asp-action="Index" class="text-decoration-none text-muted small">← Return to Catalog</a>
            </div>
        </div>
    </div>
</div>