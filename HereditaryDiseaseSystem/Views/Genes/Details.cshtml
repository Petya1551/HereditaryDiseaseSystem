@model HereditaryDiseaseSystem.Models.Gene

@{
    ViewData["Title"] = "Gene Specification";
}

<div class="row justify-content-center">
    <div class="col-md-8">

        <div class="card-master">

            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                <h5 class="mb-0">Mapping Details</h5>

                <a asp-action="Edit"
                   asp-route-id="@Model?.Id"
                   class="btn btn-sm btn-outline-primary">
                    Edit Record
                </a>
            </div>

            <div class="row mb-3">
                <div class="col-sm-4 text-muted fw-medium">
                    Symbol
                </div>

                <div class="col-sm-8">
                    <span class="badge bg-primary-subtle text-primary fs-6">
                        @Model.Symbol
                    </span>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-sm-4 text-muted fw-medium">
                    Chromosome Location
                </div>

                <div class="col-sm-8 text-dark fw-bold">
                    @Model.ChromosomeLocation
                </div>
            </div>

            <!-- Diseases -->
            <div class="mb-4">
                <h6 class="border-bottom pb-2">
                    Related Diseases
                </h6>

                @if (Model.GeneDiseases.Any())
                {
                    <ul class="list-group">
                        @foreach (var gd in Model.GeneDiseases)
                        {
                            <li class="list-group-item">
                                @gd.Disease.Name
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted small">
                        No related diseases found.
                    </p>
                }
            </div>

            <!-- Phenotypes -->
            <div class="mb-4">
                <h6 class="border-bottom pb-2">
                    Related Phenotypes
                </h6>

                @if (Model.GenePhenotypes.Any())
                {
                    <ul class="list-group">
                        @foreach (var gp in Model.GenePhenotypes)
                        {
                            <li class="list-group-item">
                                @gp.Phenotype.Name
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted small">
                        No related phenotypes found.
                    </p>
                }
            </div>

            <div class="mt-4 pt-3 border-top">
                <a asp-action="Index"
                   class="text-decoration-none text-muted small">
                    ← Return to Catalog
                </a>
            </div>

        </div>
    </div>
</div>