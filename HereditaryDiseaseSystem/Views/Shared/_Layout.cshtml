<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hereditary System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-container">
        <aside class="sidebar">
            <div class="sidebar-top-bar">
                <i class="bi bi-dna"></i> <span>HDS Portal</span>
            </div>

            <nav class="nav flex-column mt-2">
                <div class="px-3 py-2 small text-uppercase text-white-50 fw-bold" style="font-size: 0.7rem;">Modules</div>

                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">Dashboard</a>

                <div class="px-3 py-2 small text-uppercase text-white-50 fw-bold" style="font-size: 0.7rem;">Systems</div>

                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Diseases" ? "active" : "")"
                   asp-controller="Diseases" asp-action="Index">Diseases</a>

                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Genes" ? "active" : "")"
                   asp-controller="Genes" asp-action="Index">Gene Mapping</a>

                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Phenotypes" ? "active" : "")"
                   asp-controller="Phenotypes" asp-action="Index">Phenotypes</a>
            </nav>

            <div class="mt-auto p-3 border-top border-secondary">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px; font-size: 0.8rem;">
                            @User.Identity.Name?.Substring(0, 1).ToUpper()
                        </div>
                        <div class="overflow-hidden">
                            <p class="text-white small fw-bold mb-0 text-truncate">@User.Identity.Name</p>
                        </div>
                    </div>

                    <form class="form-inline"
                          asp-area="Identity"
                          asp-page="/Account/Logout"
                          method="post"
                          style="position: relative; z-index: 9999;">

                        @Html.AntiForgeryToken()

                        <button type="submit" class="btn btn-sm btn-outline-danger w-100 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </button>
                    </form>
                }
                else
                {
                    <div class="d-grid gap-2">
                        <a class="btn btn-sm btn-primary-custom" asp-area="Identity" asp-page="/Account/Login">Login</a>
                        <a class="btn btn-sm btn-outline-light" asp-area="Identity" asp-page="/Account/Register">Register</a>
                    </div>
                }
            </div>
        </aside>

        <main class="main-content">
            <header class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold">@ViewData["Title"]</h2>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="user-profile bg-white border px-3 py-1 rounded-pill small fw-medium">
                        <i class="bi bi-circle-fill text-success me-2" style="font-size: 0.5rem;"></i>
                        Logged in as: <span class="text-primary">@User.Identity.Name</span>
                    </div>
                }
            </header>

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>