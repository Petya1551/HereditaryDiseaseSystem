@model HereditaryDiseaseSystem.Models.Phenotype
@{
    ViewData["Title"] = "Edit Phenotype Record";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card-master">
            <h5 class="mb-4 border-bottom pb-2">Modify Characteristic Information</h5>
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-medium">Phenotype Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-medium">Clinical Description</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary-custom">Save Changes</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>